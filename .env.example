# Public site URL — set in Cloudflare Pages env vars (Production)
# Example: https://integrated-neuro.pages.dev
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Formspree — create a free form at https://formspree.io
# Emails go to info@integratedneuro.ca (configure in Formspree dashboard)
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/your-form-id

# Cloudflare Web Analytics — enable in Cloudflare dashboard, copy beacon token
NEXT_PUBLIC_CF_BEACON_TOKEN=your-beacon-token