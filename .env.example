# Public site URL (baked in at build time)
#
# Development — copy to .env.local:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
#
# Production — set in Cloudflare Pages → Settings → Environment variables:
# NEXT_PUBLIC_SITE_URL=https://integrated-neuro.pages.dev

# Contact form — Formspree (free) + Cloudflare Turnstile (free anti-spam)
# 1. Formspree: https://formspree.io → notify info@integratedneuro.ca
# 2. Turnstile: Cloudflare dashboard → Turnstile → add widget for your domain
#    Paste the secret key in Formspree → form settings → CAPTCHA → Turnstile
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/your-form-id
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Cloudflare Web Analytics — production builds only (not localhost dev)
NEXT_PUBLIC_CF_BEACON_TOKEN=your-beacon-token